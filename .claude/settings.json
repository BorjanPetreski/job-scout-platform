{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/stop-check.sh",
            "statusMessage": "wrap-up check"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/pre-compact.sh",
            "statusMessage": "pre-compact lesson check"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(python3 core/*)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git show*)",
      "Bash(ls*)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(grep *)",
      "Bash(jq *)",
      "Bash(mkdir -p profiles/*)",
      "Read(./**)",
      "Grep",
      "Glob",
      "Edit(./profiles/**/state/**)",
      "WebFetch",
      "WebSearch"
    ]
  }
}
